# Optional Copado API integration settings.
# Copy this file to .env and fill values locally when replacing demo data.
# Leave values blank to keep the CLI in safe demo mode.

COPADO_CICD_BASE_URL=
COPADO_CICD_TOKEN=

COPADO_AI_BASE_URL=
COPADO_AI_TOKEN=

COPADO_CRT_BASE_URL=
COPADO_CRT_TOKEN=

COPADO_HTTP_TIMEOUT=15
COPADO_DEFAULT_ENV=UAT
